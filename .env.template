# ──────────────────────────────────────────────────────────────────────────────
# DINA COSMETIC — ENVIRONMENT VARIABLE TEMPLATE
# Copy this file to .env.local for local development.
# Set all values in Vercel Environment Variables for production.
# NEVER commit actual credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── SUPABASE (Required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── STRIPE (Required) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# ── RESEND — Email (Required for order confirmation emails) ───────────────────
RESEND_API_KEY=YOUR_RESEND_API_KEY

# ── SMTP — Fallback Email (Optional) ─────────────────────────────────────────
SMTP_HOST=YOUR_SMTP_HOST
SMTP_PORT=465
SMTP_SECURE=false
SMTP_USER=YOUR_SMTP_USER
SMTP_PASS=YOUR_SMTP_PASS
SMTP_FROM=YOUR_SMTP_FROM

# ── SHIPPO — Shipping Labels (Required for fulfillment) ──────────────────────
SHIPPO_API_KEY=YOUR_SHIPPO_API_KEY

# ── WAREHOUSE / SENDER ADDRESS (Required for Shippo) ─────────────────────────
WAREHOUSE_NAME=YOUR_WAREHOUSE_NAME
WAREHOUSE_ADDRESS_LINE1=YOUR_WAREHOUSE_ADDRESS
WAREHOUSE_CITY=YOUR_CITY
WAREHOUSE_STATE=YOUR_STATE
WAREHOUSE_ZIP=YOUR_ZIP
WAREHOUSE_COUNTRY=YOUR_COUNTRY
WAREHOUSE_PHONE=YOUR_PHONE

# ── SITE URL (Required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=YOUR_DEPLOYMENT_URL
