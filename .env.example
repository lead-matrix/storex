# --- THE OBSIDIAN PALACE (ENVIRONMENT TEMPLATE) ---
# Copy this to .env.local and fill in your credentials.
# NEVER commit your actual .env.local to version control.

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Outbound Communications
RESEND_API_KEY=re_...

# SMTP Configuration (Optional, for NodeMailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Warehouse details for Shipping
WAREHOUSE_NAME=
WAREHOUSE_ADDRESS_LINE1=
WAREHOUSE_CITY=
WAREHOUSE_STATE=
WAREHOUSE_ZIP=
WAREHOUSE_COUNTRY=
WAREHOUSE_PHONE=

# Deployment URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000